# Server configuration
PORT=3001

# JWT secret - REQUIRED in production. Use a strong random string (min 32 chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Default admin credentials (only used if admin.json does not exist yet)
ADMIN_DEFAULT_EMAIL=Administrador@Hublab.cl
ADMIN_DEFAULT_PASSWORD=
